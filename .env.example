# ── Local development ────────────────────────────────────────────────────────

# Your Flipkart login email (same Gmail address that receives the OTP)
FLIPKART_USERNAME=your_email@gmail.com

# Gmail OAuth 2.0 — Desktop app credentials from Google Cloud Console
# APIs & Services → Credentials → your Desktop OAuth client → edit → copy values
GMAIL_CLIENT_ID=xxxxxxxxxxxxxx.apps.googleusercontent.com
GMAIL_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxxxxxxxxxx

# ── Render / cloud deployment (add these in Render dashboard → Environment) ──

# Paste the full contents of token.json here after running test_gmail_auth.py locally
GMAIL_TOKEN_JSON=

# Paste the full contents of auth_state.json here after the first successful scrape
# (the app logs this value to stdout automatically after each scrape)
FLIPKART_AUTH_STATE=

# Optional override
# GMAIL_TOKEN_FILE=token.json

# How many recent Flipkart orders to scrape by default. Used by both the CLI
# (when --orders isn't passed) and the Flask /api/products POST (when the
# request body omits "orders"). Explicit values still override this.
ORDERS_TO_SCRAPE=10

# Geolocation handed to the browser context. Flipkart Minutes gates product
# pages on a known location — without these, every Minutes click strands on
# the hyperlocal-preview interstitial. Defaults to Bengaluru; override if
# your delivery address is elsewhere.
FLIPKART_LAT=12.9716
FLIPKART_LNG=77.5946

# Pincode entered when Flipkart shows a "Check delivery" / "Enter pincode"
# prompt on the preview interstitial OR on the product page itself. Match it
# to the geolocation above so you actually receive serviceable results.
FLIPKART_PINCODE=560094

# ── Salesforce sync (optional) ───────────────────────────────────────────────
# When all four SF_* vars are set, after every successful scrape each unique
# product is pushed to Salesforce: Grocery_Product__c records are matched by
# title__c, then number_of_times_purchased__c and last_ordered_date__c are
# updated. Titles with no matching record are logged and skipped — new
# Grocery_Product__c records are NEVER created.
# Uses OAuth 2.0 client_credentials against a Salesforce Connected App.

SF_TOKEN_URL=https://<your-domain>.my.salesforce.com/services/oauth2/token
SF_CLIENT_ID=
SF_CLIENT_SECRET=
SF_API_ENDPOINT=https://<your-domain>.my.salesforce.com/services/data/v57.0/sobjects/Grocery_Product__c/
